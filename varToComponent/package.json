{
  "name": "var-to-component",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:plugin\"",
    "dev:ui": "vite build --watch --mode development",
    "dev:plugin": "esbuild src/plugin/code.ts --bundle --outfile=dist/code.js --target=es6 --watch",
    "build": "npm run build:ui && npm run build:plugin",
    "build:ui": "vite build",
    "build:plugin": "esbuild src/plugin/code.ts --bundle --outfile=dist/code.js --target=es6",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.101.0",
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-plugin-singlefile": "^2.1.0",
    "vue-tsc": "^2.2.8"
  }
}
