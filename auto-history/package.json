{
  "name": "auto-history",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build",
    "dev:ui": "vite build --mode development",
    "dev:plugin": "node build-plugin.mjs",
    "build": "npm run build:ui && npm run build:plugin",
    "build:ui": "vite build",
    "build:plugin": "node build-plugin.mjs",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.101.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "esbuild": "^0.25.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-plugin-singlefile": "^2.1.0",
    "vue-tsc": "^2.2.8"
  }
}
